# Producción VPS - copiar a /opt/tamagotchi/.env y rellenar

# Postgres
POSTGRES_USER=tama
POSTGRES_PASSWORD=GENERA_PASSWORD_FUERTE_AQUI
POSTGRES_DB=tama
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT (genera: openssl rand -hex 32)
JWT_SECRET=GENERA_SECRET_HEX_32_AQUI
JWT_EXPIRE_MIN=60
JWT_REFRESH_DAYS=30

# Servicios (no tocar en prod)
AUTH_PORT=8081
PET_PORT=8082
SOCIAL_PORT=8083
NOTIF_PORT=8084
GATEWAY_PORT=8080

# Game
TICK_INTERVAL_SEC=30
LOG_LEVEL=info

# Caddy / dominios públicos
ACME_EMAIL=tu-email@dominio.com
WEB_DOMAIN=tama.tudominio.me
API_DOMAIN=api.tama.tudominio.me

# URLs build-time pa frontend + CORS
PUBLIC_WEB_URL=https://tama.tudominio.me
PUBLIC_API_URL=https://api.tama.tudominio.me
