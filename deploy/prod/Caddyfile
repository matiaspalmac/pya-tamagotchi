{
	email {$ACME_EMAIL}
}

# Frontend
{$WEB_DOMAIN} {
	encode zstd gzip
	reverse_proxy web:80

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options nosniff
		Referrer-Policy strict-origin-when-cross-origin
	}
}

# API + WebSocket
{$API_DOMAIN} {
	encode zstd gzip
	reverse_proxy gateway:8080

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options nosniff
	}
}
